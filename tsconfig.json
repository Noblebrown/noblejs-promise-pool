{
    "compilerOptions": {
        "types": ["node"],
        "rootDir": "./src",
        "outDir": "./dist",
        "target": "esnext",
        "module": "CommonJS",
        "noImplicitAny": true,
        "strictNullChecks": true,
        "esModuleInterop": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "inlineSourceMap": true,
        "declaration": true,
        "declarationMap": true
    },
    "include": ["src"]
}